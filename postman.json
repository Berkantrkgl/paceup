{
    "info": {
        "_postman_id": "d9c8b1c9-9999-8888-7777-111213141517",
        "name": "PaceUp",
        "description": "Backend geliştirme ve test süreçleri için tam kapsamlı API koleksiyonu.\n\nÖzellikler:\n- Tüm modeller için (User, Program, Workout, Result, Notification)  işlemleri.\n- Otomatik ID yakalama (Bir kayıt oluşturunca ID'si değişkene atanır, güncelleme/silme işlemlerinde otomatik kullanılır).\n- Yanlış veri düzeltme senaryoları (Update Gender, Fix Date vb.).\n- Dashboard ve İstatistik uçları.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "0. Auth (Token Management)",
            "item": [
                {
                    "name": "Register (New User)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.collectionVariables.set(\"access_token\", jsonData.access);",
                                    "    pm.collectionVariables.set(\"refresh_token\", jsonData.refresh);",
                                    "    pm.collectionVariables.set(\"user_id\", jsonData.id);",
                                    "    console.log(\"User Registered & Logged In\");",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"test.admin@runapp.com\",\n    \"password\": \"Admin123!\",\n    \"first_name\": \"Test\",\n    \"last_name\": \"Kullanıcı\",\n    \"gender\": \"male\",\n    \"weight\": 80,\n    \"height\": 180,\n    \"current_pace\": 360,\n    \"weekly_goal\": 3\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/users/",
                            "host": ["{{base_url}}"],
                            "path": ["users", ""]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Login (Get Token)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.access) {",
                                    "    pm.collectionVariables.set(\"access_token\", jsonData.access);",
                                    "    pm.collectionVariables.set(\"refresh_token\", jsonData.refresh);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"test.admin@runapp.com\",\n    \"password\": \"Admin123!\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/token/",
                            "host": ["{{base_url}}"],
                            "path": ["token", ""]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Refresh Token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if(jsonData.access) {",
                                    "    pm.collectionVariables.set(\"access_token\", jsonData.access);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/token/refresh/",
                            "host": ["{{base_url}}"],
                            "path": ["token", "refresh", ""]
                        }
                    },
                    "response": []
                }
            ]
        },
