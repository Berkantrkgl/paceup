# Shared with Django — used to verify JWT (HS256). MUST match DJANGO_SECRET_KEY
# in the Django service. Rotating one requires rotating both.
DJANGO_SECRET_KEY=change-me-to-match-django

# Postgres connection string for LangGraph AsyncPostgresSaver (same RDS as Django).
# Format: postgresql://user:password@host:5432/dbname
# DATABASE_URL is also accepted — useful when sharing the Django secret.
DB_URI=postgresql://paceup:paceup_dev@db:5432/paceup

# Django REST API base URL (no trailing slash, must end in /api)
# Prod: https://your-domain.com/api
# Dev:  http://localhost:8000/api
BACKEND_URL=http://localhost:8000/api

# Timeout for upstream Django calls (seconds). Plan generation can take 20s+
BACKEND_HTTP_TIMEOUT=30

# CORS — comma-separated. Leave empty for "*" (dev only).
# Prod: https://your-domain.com
ALLOWED_ORIGINS=

# AWS Bedrock (eu-central-1)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1

# Logging — DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO
