# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Database — prod: RDS, dev: compose postgres
DATABASE_URL=postgres://paceup:paceup_dev@db:5432/paceup

# AWS S3 (profil görselleri)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_DEFAULT_REGION=eu-central-1

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sign in with Apple — iOS bundle ID (identity_token "aud" claim must match)
APPLE_CLIENT_ID=com.example.PaceUp
